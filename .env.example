# Database Connection
# IMPORTANT: If using a cloud database, use the public address/URL provided by your provider.
# If connecting to your local machine, use a tunnel like ngrok (e.g., ngrok tcp 5433)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=rpt_monitor_data
DB_SSL=false

# Or use a full connection string (recommended for cloud databases like Neon/Supabase)
# DATABASE_URL=postgresql://postgres:change-me@localhost:5433/rpt_monitor_data

JWT_SECRET=replace-with-a-long-random-secret

# Optional integrations
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=
SEED_ADMIN_PASSWORD=
SEED_QUEUE_PASSWORD=
